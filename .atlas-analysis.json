  "keyFeatures": [
    "Automatic client-side caching with request deduplication",
    "useQuery composable for declarative data fetching",
    "useMutation composable for data mutations with lifecycle hooks",
    "Query cache invalidation and automatic refetching",
    "Optimistic updates for instant UI feedback",
    "Infinite and paginated query support",
    "Out-of-the-box SSR support via onServerPrefetch",
    "Plugin system for extending functionality (retry, auto-refetch, delay, cache persistence)",
    "Full TypeScript support with type-safe cache access",
    "Nuxt module integration",
    "Zero dependencies beyond Pinia and Vue",
    "~2kb baseline bundle size, fully tree-shakeable"
  ],
